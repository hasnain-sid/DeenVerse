{
  "name": "deenverse",
  "private": true,
  "description": "Islamic Social Media Platform",
  "workspaces": [
    "packages/shared",
    "frontend",
    "backend",
    "packages/mobile"
  ],
  "scripts": {
    "build": "npm run build:web && node -e \"const fs=require('fs');if(fs.existsSync('frontend/dist')){if(fs.existsSync('dist'))fs.rmSync('dist',{recursive:true,force:true});fs.cpSync('frontend/dist','dist',{recursive:true});}\"",
    "dev:web": "cd frontend && npm run dev",
    "build:shared": "cd packages/shared && npx tsc",
    "dev:backend": "npm run build:shared && cd backend && npm run dev",
    "dev:mobile": "cd packages/mobile && npx expo start",
    "install:all": "npm install",
    "build:web": "cd frontend && npm run build",
    "check:integrity": "node scripts/check-feature-integrity.js"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0"
  }
}
